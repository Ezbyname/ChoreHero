{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*":              ["src/*"],
      "@/components/*":  ["src/components/*"],
      "@/screens/*":     ["src/screens/*"],
      "@/navigation/*":  ["src/navigation/*"],
      "@/theme/*":       ["src/theme/*"],
      "@/content/*":     ["src/content/*"]
    }
  },
  "exclude": ["e2e", "playwright.config.ts", "node_modules"]
}
